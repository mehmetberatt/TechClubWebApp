@{
    ViewData["Title"] = "Hizmetlerimiz";
}

<div class="hero-section text-center py-5" style="background: linear-gradient(135deg, var(--secondary-navy) 0%, #173263 100%);">
    <div class="container py-5 mt-5">
        <h1 class="display-4 fw-black text-white mb-4">Hizmetlerimiz</h1>
        <p class="lead text-white opacity-75 mx-auto" style="max-width: 700px;">
            Kurumsal ve bireysel teknoloji ihtiyaçlarınız için uçtan uca, yenilikçi ve güvenilir çözümler sunuyoruz.
        </p>
    </div>
</div>

<div class="container py-5 mt-4">
    <div class="row g-4 justify-content-center">
        <!-- Hizmet 1 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 p-md-5 card-modern hover-lift transition-all">
                <div class="bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mx-auto mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-code-slash text-primary-blue fs-1"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Özel Yazılım Geliştirme</h4>
                <p class="text-muted flex-grow-1">Şirketinizin ihtiyaçlarına tam uyan, ölçeklenebilir ve yüksek performanslı web, masaüstü veya mobil yazılım çözümleri üretiyoruz.</p>
            </div>
        </div>

        <!-- Hizmet 2 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 p-md-5 card-modern hover-lift transition-all">
                <div class="bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mx-auto mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-robot text-success fs-1"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Yapay Zeka Çözümleri</h4>
                <p class="text-muted flex-grow-1">Büyük verinizi anlamlandırarak, iş süreçlerinizi otomatize eden derin öğrenme ve modern yapay zeka entegrasyonları sağlıyoruz.</p>
            </div>
        </div>

        <!-- Hizmet 3 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 p-md-5 card-modern hover-lift transition-all">
                <div class="bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mx-auto mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-cloud-check text-warning fs-1"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Bulut Bilişim & Mimari</h4>
                <p class="text-muted flex-grow-1">Sunucu maliyetlerini düşüren, her zaman erişilebilir ve güvenli bulut mimarileri kurarak sistem geçişlerinizi yönetiyoruz.</p>
            </div>
        </div>

        <!-- Hizmet 4 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 p-md-5 card-modern hover-lift transition-all">
                <div class="bg-purple bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mx-auto mb-4" style="width: 80px; height: 80px; background-color: rgba(111, 66, 193, 0.1);">
                    <i class="bi bi-shield-lock text-purple fs-1" style="color: #6f42c1;"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Siber Güvenlik</h4>
                <p class="text-muted flex-grow-1">Veri ihlallerine ve siber saldırılara karşı sistemlerinizi test ediyor, zaaflarınızı raporlayarak tam güvenlik kalkanı sağlıyoruz.</p>
            </div>
        </div>
        
        <!-- Hizmet 5 -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 p-md-5 card-modern hover-lift transition-all">
                <div class="bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mx-auto mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-phone text-danger fs-1"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Mobil Uygulamalar</h4>
                <p class="text-muted flex-grow-1">Hem iOS hem Android platformlarında kusursuz UX/UI deneyimi sunan, modern ve hızlı native veya cross-platform mobil uygulamalar tasarlıyoruz.</p>
            </div>
        </div>
    </div>
</div>
