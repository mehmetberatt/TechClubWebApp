@{
    ViewData["Title"] = "Kariyer Fırsatları";
}

<div class="hero-section text-center py-5" style="background: linear-gradient(135deg, var(--secondary-navy) 0%, #173263 100%);">
    <div class="container py-5 mt-5">
        <h1 class="display-4 fw-black text-white mb-4">Aramıza Katılın!</h1>
        <p class="lead text-white opacity-75 mx-auto" style="max-width: 700px;">
            Milyonlarca insana dokunacak projelerde yer alacak, yenilikçi ve tutkulu takım arkadaşları arıyoruz.
        </p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center text-muted py-5">
            <i class="bi bi-briefcase display-1 text-primary opacity-50 mb-4"></i>
            <h3 class="fw-bold text-navy mb-3">Şu anda açık pozisyon bulunmuyor</h3>
            <p class="lead">Gelecekteki fırsatlar için lütfen bu sayfayı takip etmeye devam edin.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary mt-4 rounded-pill px-4">Ana Sayfaya Dön</a>
        </div>
    </div>
</div>
