@{
    ViewData["Title"] = "Gizlilik Politikası";
}

<div class="hero-section text-center py-5" style="background: linear-gradient(135deg, var(--secondary-navy) 0%, #173263 100%);">
    <div class="container py-5 mt-5">
        <h1 class="display-4 fw-black text-white mb-4">Gizlilik Politikası</h1>
        <p class="lead text-white opacity-75 mx-auto" style="max-width: 700px;">
            Verilerinizin güvenliği ve gizliliği bizim için en büyük önceliktir.
        </p>
    </div>
</div>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <h3 class="fw-bold text-navy mb-4 border-bottom pb-3">1. Toplanan Veriler</h3>
                <p class="text-muted mb-5 text-justify">
                    TechClub olarak web sitemizi ziyaretiniz sırasında IP adresiniz, tarayıcı bilgileriniz, ziyaret edilen sayfalar gibi anonim istatistiksel verileri toplamaktayız. İletişim formları veya başvuru formları aracılığıyla kendi rızanızla ilettiğiniz ad, soyad, e-posta adresi gibi kişisel veriler ise hizmet sunmak amacı ile güvenle saklanmaktadır.
                </p>

                <h3 class="fw-bold text-navy mb-4 border-bottom pb-3">2. Verilerin Kullanımı</h3>
                <p class="text-muted mb-5 text-justify">
                    Toplanan veriler yalnızca size daha iyi hizmet sunmak, başvurularınızı değerlendirmek ve onayınız dahilinde sizlere duyuru ve bilgilendirme sağlamak amacıyla kullanılmaktadır. Yasal zorunluluklar haricinde verileriniz asla üçüncü şahıslarla paylaşılmamaktadır.
                </p>

                <h3 class="fw-bold text-navy mb-4 border-bottom pb-3">3. Veri Güvenliği</h3>
                <p class="text-muted mb-5 text-justify">
                    Kişisel verilerinizin korunması için sektör standartlarına uygun tüm şifreleme ve güvenlik ağ protokollerini kullanıyoruz. Ancak, internet üzerinden yapılan hiçbir veri iletiminin %100 güvenli olamayacağını hatırlatmak isteriz.
                </p>

                <h3 class="fw-bold text-navy mb-4 border-bottom pb-3">4. İletişim</h3>
                <p class="text-muted mb-0 text-justify">
                    Gizlilik politikamız ile ilgili soru veya veri silme talepleriniz için lütfen <a href="@Url.Action("Contact", "Home")" class="text-primary-blue text-decoration-none fw-bold">iletişim sayfamız</a> üzerinden bizimle irtibata geçin. Veya bize doğrudan <a href="mailto:info@techclub.com" class="text-primary-blue text-decoration-none fw-bold">info@techclub.com</a> adresinden yazın.
                </p>
            </div>
        </div>
    </div>
</div>
