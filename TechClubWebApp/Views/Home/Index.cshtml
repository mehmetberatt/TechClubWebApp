@model TechClubWebApp.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div id="mainCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner">
        @if (Model.Banners != null && Model.Banners.Any())
        {
            var isFirst = true;
            foreach (var banner in Model.Banners)
            {
                <div class="carousel-item @(isFirst ? "active" : "")">
                    <img src="@banner.ImageUrl" class="d-block w-100" alt="Banner Görseli" style="height: 60vh; object-fit: cover;">

                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-75 p-4 rounded-3 shadow-lg">
                        <h1 class="display-5 fw-bold text-white mb-3">@banner.Title</h1>
                        <a href="@banner.LinkUrl" class="btn btn-primary btn-lg px-4 rounded-pill">Detaylı İncele</a>
                    </div>
                </div>
                isFirst = false;
            }
        }
        else
        {
            <div class="carousel-item active">
                <img src="https://via.placeholder.com/1920x800?text=Kurumsal+Banner+Gorseli+(1920x800)" class="d-block w-100" alt="Placeholder" style="height: 60vh; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-75 p-4 rounded-3">
                    <h1 class="display-5 fw-bold text-white">Sisteme Banner Eklenmedi</h1>
                </div>
            </div>
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Önceki</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sonraki</span>
    </button>
</div>

<div class="container">
    <div class="row mb-5 py-4">
        <div class="col-12 text-center mb-4">
            <h2 class="fw-bold text-dark display-6">Güncel Duyurular ve Haberler</h2>
            <div class="mx-auto bg-primary" style="height: 4px; width: 80px; border-radius: 2px;"></div>
        </div>

        @if (Model.Announcements != null && Model.Announcements.Any())
        {
            foreach (var announcement in Model.Announcements)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden transition-hover">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary px-3 py-2 rounded-pill">Duyuru</span>
                                <small class="text-muted fw-semibold">@announcement.CreatedDate.ToString("dd MMMM yyyy")</small>
                            </div>
                            <h5 class="card-title fw-bold text-dark mb-3">@announcement.Title</h5>
                            <p class="card-text text-secondary">
                                @(announcement.Content.Length > 120 ? announcement.Content.Substring(0, 120) + "..." : announcement.Content)
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 p-4 pt-0">
                            <a href="#" class="text-primary fw-bold text-decoration-none">Haberi Oku &rarr;</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="bg-light py-5">
    <div class="container my-4">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h2 class="fw-bold text-dark display-6">Yaklaşan Etkinlikler</h2>
                <div class="mx-auto bg-primary" style="height: 4px; width: 80px; border-radius: 2px;"></div>
            </div>

            @if (Model.Events != null && Model.Events.Any())
            {
                foreach (var ev in Model.Events)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">
                            <div class="row g-0 h-100">
                                <div class="col-md-5">
                                    <img src="@ev.ImageUrl" class="img-fluid w-100 h-100" alt="Etkinlik Afişi" style="object-fit: cover; min-height: 250px;">
                                </div>
                                <div class="col-md-7 d-flex flex-column">
                                    <div class="card-body p-4 flex-grow-1">
                                        <h5 class="card-title fw-bold text-dark mb-3">@ev.Title</h5>
                                        <p class="card-text text-secondary mb-4">@ev.Description</p>

                                        <div class="mt-auto">
                                            <div class="d-flex align-items-center mb-2 text-muted font-monospace">
                                                <strong class="text-dark me-2">Tarih:</strong> @ev.EventDate.ToString("dd.MM.yyyy - HH:mm")
                                            </div>
                                            <div class="d-flex align-items-center text-muted font-monospace">
                                                <strong class="text-dark me-2">Konum:</strong> @ev.Location
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="career-section py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-7 mb-4 mb-lg-0">
                <span class="badge bg-light text-primary px-3 py-2 rounded-pill mb-3 fw-bold shadow-sm">Kariyer Fırsatları</span>
                <h2 class="display-5 fw-bold text-white mb-4">Geleceği Birlikte Kodlayalım</h2>
                <p class="lead text-white-50 mb-5" style="line-height: 1.8;">
                    Dinamik ve yenilikçi projelerle dolu bir ortamda, sürekli gelişeceğin bir kariyer seni bekliyor. Harika bir ekibin parçası olmak istiyorsan, TechClub tam sana göre!
                </p>
                <a href="#" class="btn btn-light btn-lg text-primary fw-bold px-5 py-3 rounded-pill shadow">Detaylar için ulaşın &rarr;</a>
            </div>
            <div class="col-lg-5 text-center">
                <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=600&auto=format&fit=crop" class="img-fluid rounded-4 shadow-lg border border-white border-opacity-25" alt="TechClub Ekibi" style="transform: rotate(2deg); transition: transform 0.3s ease;" onmouseover="this.style.transform='rotate(0deg)'" onmouseout="this.style.transform='rotate(2deg)'">
            </div>
        </div>
    </div>
</div>