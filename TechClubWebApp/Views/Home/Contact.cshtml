@{
    ViewData["Title"] = "İletişim";
}

<div class="container py-5 mt-5">
    <div class="row gx-5 justify-content-center">
        <div class="col-lg-8">
            <h1 class="display-4 fw-black text-navy mb-4 text-center">Bize Ulaşın</h1>
            <p class="lead text-muted text-center mb-5">
                Sorularınız, projeleriniz veya işbirlikleri için bizimle iletişime geçebilirsiniz.
            </p>

            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light-gray shadow-sm rounded-4 text-center p-4">
                        <i class="bi bi-geo-alt display-4 text-primary mb-3"></i>
                        <h4 class="fw-bold">Ofisimiz</h4>
                        <p class="text-muted">Teknopark İstanbul, Pendik<br>İstanbul, Türkiye</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light-gray shadow-sm rounded-4 text-center p-4">
                        <i class="bi bi-envelope display-4 text-primary mb-3"></i>
                        <h4 class="fw-bold">E-Posta</h4>
                        <p class="text-muted"><a href="mailto:info@techclub.com" class="text-decoration-none">info@techclub.com</a></p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <h3 class="fw-bold text-navy mb-4">İletişim Formu</h3>
                <form>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Adınız Soyadınız</label>
                            <input type="text" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">E-Posta Adresiniz</label>
                            <input type="email" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Konu</label>
                            <input type="text" class="form-control bg-light border-0" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Mesajınız</label>
                            <textarea class="form-control bg-light border-0" rows="5" required></textarea>
                        </div>
                        <div class="col-12 text-end mt-4">
                            <button type="button" class="btn btn-primary-custom rounded-pill px-5 py-2 fw-bold" onclick="alert('Demo amaçlıdır. Mesajınız alınmıştır.')">Gönder</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
