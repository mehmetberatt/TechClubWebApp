@model TeknolojiKulubu.Models.Banner

@{
    ViewData["Title"] = "Yeni Banner / Vitrin Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="dash-card p-4 p-md-5">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Banners" class="text-secondary me-3 bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; transition: 0.2s;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h5 class="fw-bold text-dark mb-1">Yeni Ana Sayfa Vitrini Oluştur</h5>
                    <p class="text-muted small mb-0">Ana sayfada ilk göze çarpacak mesajı girin.</p>
                </div>
            </div>

            <hr class="border-light mb-4">

            <form asp-action="CreateBanner" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-semibold text-dark small">Ana Satır (Büyük Başlık)</label>
                    <input asp-for="Title" class="form-control form-control-lg bg-light border-0" placeholder="Örn: Geleceğin Çözümleri" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-dark small">Arka Plan Görseli</label>
                    <div class="position-relative">
                        <input type="file" name="imageFile" id="imageFile" class="form-control d-none" accept="image/*" onchange="document.getElementById('fileNameLabel').textContent = this.files[0].name" />
                        <label for="imageFile" class="form-control bg-light border-0 d-flex align-items-center justify-content-between" style="cursor:pointer; min-height: 48px;">
                            <span id="fileNameLabel" class="text-muted">Görsel Seçmek İçin Tıklayın...</span>
                            <span class="btn btn-sm btn-secondary rounded-2 px-3 py-1">Gözat</span>
                        </label>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold text-dark small">Detay / Açıklama Ekleyin (İsteğe Bağlı)</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3" placeholder="Örn: Geniş kapsamlı araştırmalarla şekillenen..."></textarea>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-5 border-top pt-4">
                    <a asp-action="Banners" class="btn btn-light border px-4 fw-semibold text-muted">İptal</a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-save me-2"></i> Kaydet ve Yayınla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
