@model TechClubWebApp.Models.AdminUser

@{
    ViewData["Title"] = "Yönetici Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="dash-card p-4 p-md-5">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Admins" class="text-secondary me-3 bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; transition: 0.2s;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h5 class="fw-bold text-dark mb-1">Yöneticiyi Düzenle</h5>
                    <p class="text-muted small mb-0">Bilgileri ya da parolyı güncelleyebilirsiniz.</p>
                </div>
            </div>

            <hr class="border-light mb-4">

            <form asp-action="EditAdmin" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PasswordHash" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-4">
                    <label asp-for="Username" class="form-label fw-semibold text-dark small">Kullanıcı Adı</label>
                    <input asp-for="Username" class="form-control form-control-lg bg-light border-0" required />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label for="NewRawPassword" class="form-label fw-semibold text-dark small">Yeni Şifre Belirle (Değiştirmek İstemiyorsanız Boş Bırakın)</label>
                    <input type="password" id="NewRawPassword" name="NewRawPassword" class="form-control form-control-lg bg-light border-0" placeholder="Yeni şifre (isteğe bağlı)" />
                </div>

                <div class="mb-4 pt-2">
                    <label asp-for="Role" class="form-label fw-semibold text-dark small">Yetki Seviyesi (Rol)</label>
                    <select asp-for="Role" class="form-select form-select-lg bg-light border-0">
                        <option value="Administrator">Tam Yetkili (Administrator)</option>
                        <option value="Editor">Editör</option>
                    </select>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-5 border-top pt-4">
                    <a asp-action="Admins" class="btn btn-light border px-4 fw-semibold text-muted">İptal</a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                        <i class="bi bi-pencil-square me-2"></i> Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
