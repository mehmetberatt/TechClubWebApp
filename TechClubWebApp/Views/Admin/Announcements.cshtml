@model IEnumerable<TeknolojiKulubu.Models.Announcement>

@{
    ViewData["Title"] = "Duyuru Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dash-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold text-dark mb-1">Sistemdeki Duyurular</h5>
            <p class="text-muted small mb-0">Aktif ve pasif tüm haberleri yönetin</p>
        </div>
        <a asp-action="CreateAnnouncement" class="btn btn-primary fw-semibold px-4 rounded-3 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Yeni Ekle
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light text-muted small text-uppercase">
                <tr>
                    <th class="py-3 px-4">Başlık</th>
                    <th class="py-3">Tarih</th>
                    <th class="py-3 text-center">Durum</th>
                    <th class="py-3 text-end px-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-medium text-dark" style="max-width: 300px;">
                                <div class="text-truncate" title="@item.Title">@item.Title</div>
                            </td>
                            <td class="text-muted small">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3">Pasif</span>
                                }
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditAnnouncement" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    
                                    <form asp-action="DeleteAnnouncement" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');">
                                        <button type="submit" class="btn btn-sm btn-light border text-danger">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary opacity-50"></i>
                            Kayıtlı hiçbir duyuru bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
