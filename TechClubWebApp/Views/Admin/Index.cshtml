@{
    ViewData["Title"] = "Kontrol Paneli (Dashboard)";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="dash-card p-4 h-100 border-top border-primary border-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h6 class="text-muted fw-bold mb-1 text-uppercase">Aktif Duyurular</h6>
                    <h2 class="fw-black text-dark mb-0">--</h2>
                </div>
                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3">
                    <i class="bi bi-megaphone-fill fs-4"></i>
                </div>
            </div>
            <p class="text-muted small mb-0"><i class="bi bi-arrow-up-short text-success"></i> Yeni bildirimler sistemde yetki bekliyor.</p>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="dash-card p-4 h-100 border-top border-success border-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h6 class="text-muted fw-bold mb-1 text-uppercase">Gelecek Etkinlikler</h6>
                    <h2 class="fw-black text-dark mb-0">--</h2>
                </div>
                <div class="bg-success bg-opacity-10 text-success p-3 rounded-3">
                    <i class="bi bi-calendar-event-fill fs-4"></i>
                </div>
            </div>
            <p class="text-muted small mb-0"><i class="bi bi-clock-history"></i> Takvim senkronizasyonu aktif.</p>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="dash-card p-4 h-100 border-top border-warning border-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h6 class="text-muted fw-bold mb-1 text-uppercase">Sistem Durumu</h6>
                    <h2 class="fw-black text-dark mb-0">Online</h2>
                </div>
                <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3">
                    <i class="bi bi-hdd-network-fill fs-4"></i>
                </div>
            </div>
            <p class="text-muted small mb-0"><i class="bi bi-check-circle-fill text-success"></i> Veritabanı bağlantısı sağlıklı.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="dash-card p-4">
            <h5 class="fw-bold mb-4">Hızlı Erişim</h5>
            <div class="d-flex flex-wrap gap-3">
                <a asp-controller="Admin" asp-action="CreateAnnouncement" class="btn btn-primary px-4 py-2 fw-semibold rounded-3 shadow-sm">
                    <i class="bi bi-plus-lg me-2"></i> Yeni Duyuru Ekle
                </a>
                <button class="btn btn-light px-4 py-2 fw-semibold rounded-3 border">
                    <i class="bi bi-envelope-paper me-2"></i> Mesajları Oku
                </button>
                <button class="btn btn-light px-4 py-2 fw-semibold rounded-3 border">
                    <i class="bi bi-gear me-2"></i> Sistem Ayarları
                </button>
            </div>
        </div>
    </div>
</div>
