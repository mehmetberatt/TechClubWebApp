@model IEnumerable<TeknolojiKulubu.Models.Banner>

@{
    ViewData["Title"] = "Ana Sayfa Vitrin Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dash-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold text-dark mb-1">Vitrin (Banner) Yönetimi</h5>
            <p class="text-muted small mb-0">Ana sayfa en üstündeki devasa hero metinlerini ayarlayın</p>
        </div>
        <a asp-action="CreateBanner" class="btn btn-primary fw-semibold px-4 rounded-3 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i> Yeni Ekle
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["ErrorMessage"]</div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light text-muted small text-uppercase">
                <tr>
                    <th class="py-3 px-4">Vitrin Başlığı</th>
                    <th class="py-3">Açıklama/Link</th>
                    <th class="py-3 text-end px-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-medium text-dark">
                                @item.Title
                            </td>
                            <td class="text-muted small">@item.LinkUrl</td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditBanner" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>
                                    
                                    <form asp-action="DeleteBanner" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Silmek istediğinizden emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-light border text-danger">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-images fs-1 d-block mb-3 text-secondary opacity-50"></i>
                            Gösterilecek Banner bulunamadı. Lütfen yeni bir resim veya başlık ekleyin.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
