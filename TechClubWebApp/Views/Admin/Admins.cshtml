@model IEnumerable<TechClubWebApp.Models.AdminUser>

@{
    ViewData["Title"] = "Yöneticiler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="dash-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold text-dark mb-1">Sistem Yöneticileri</h5>
            <p class="text-muted small mb-0">Panele giriş yapabilen kullanıcılar</p>
        </div>
        <a asp-action="CreateAdmin" class="btn btn-primary fw-semibold px-4 rounded-3 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i> Yeni Ekle
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 rounded-3 border-danger border-opacity-25" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle border">
            <thead class="table-light text-muted small text-uppercase">
                <tr>
                    <th class="py-3 px-4">Kullanıcı Adı</th>
                    <th class="py-3 text-center">Yetki (Rol)</th>
                    <th class="py-3">Kayıt Tarihi</th>
                    <th class="py-3 text-end px-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var admin in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-navy">
                                <i class="bi bi-person-circle me-2 text-primary"></i>@admin.Username
                            </td>
                            <td class="text-center">
                                <span class="badge bg-purple bg-opacity-10 text-purple border border-purple border-opacity-25 rounded-pill px-3">@admin.Role</span>
                            </td>
                            <td class="text-muted small">@admin.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditAdmin" asp-route-id="@admin.Id" class="btn btn-sm btn-light border text-primary">
                                        <i class="bi bi-pencil-square"></i> Düzenle
                                    </a>
                                    
                                    <form asp-action="DeleteAdmin" asp-route-id="@admin.Id" method="post" class="d-inline" onsubmit="return confirm('Bu yöneticiyi silmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-light border text-danger">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-people fs-1 d-block mb-3 text-secondary opacity-50"></i>
                            Kayıtlı hiçbir yönetici bulunamadı.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
