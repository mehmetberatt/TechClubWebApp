@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistem Girişi</title>
    
   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .login-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            width: 100%;
            max-width: 420px;
            background: white;
            padding: 40px;
        }
        .form-control {
            padding: 12px 16px;
            border-radius: 8px;
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
        }
        .form-control:focus {
            background-color: white;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.15);
        }
        .btn-login {
            padding: 12px;
            font-weight: 600;
            border-radius: 8px;
            background-color: #212529;
            color: white;
            border: none;
            transition: all 0.3s ease;
        }
        .btn-login:hover {
            background-color: #343a40;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="text-center mb-4">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                <i class="bi bi-shield-lock-fill fs-3 text-secondary"></i>
            </div>
            <h4 class="fw-bold text-dark">Sistem Girişi</h4>
            <p class="text-muted small">Lütfen yetkili bilgilerinizi giriniz</p>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger p-3 small mb-4 rounded-3 text-center border-0 bg-danger bg-opacity-10 text-danger" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
            </div>
        }

        <form asp-controller="Admin" asp-action="Login" method="post">
            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold">Kullanıcı Adı</label>
                <input type="text" class="form-control" name="username" required autocomplete="off" autofocus placeholder="Örn: Userxxx" />
            </div>

            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold">Şifre</label>
                <input type="password" class="form-control" name="password" required placeholder="••••••••" />
            </div>

            <button type="submit" class="btn btn-login w-100 mt-2">
                Otomatik Giriş Yap
            </button>
            <div class="text-center mt-4">
                 <a href="/" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i> Siteye Dön</a>
            </div>
        </form>
    </div>

</body>
</html>
