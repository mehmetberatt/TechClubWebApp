<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechClub</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    
    <!-- Özel CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top" style="background-color: #0b1120; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <div class="container py-2">
                <a class="navbar-brand d-flex align-items-center gap-2 text-white" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-fill text-primary-blue fs-4"></i>
                    <span class="fs-4 fw-black letter-spacing-tight">TechClub.</span>
                </a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav align-items-lg-center gap-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-light @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active text-primary-blue" : "")" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-light @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active text-primary-blue" : "")" asp-controller="Home" asp-action="About">Hakkımızda</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-light @(ViewContext.RouteData.Values["Action"]?.ToString() == "Services" ? "active text-primary-blue" : "")" asp-controller="Home" asp-action="Services">Hizmetler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-light @(ViewContext.RouteData.Values["Action"]?.ToString() == "Career" ? "active text-primary-blue" : "")" asp-controller="Home" asp-action="Career">Kariyer</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer-dark py-4 mt-auto">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2 mb-3 mb-md-0">
                    <i class="bi bi-lightning-fill text-primary-blue fs-5"></i>
                    <span class="fs-5 fw-bold text-white">TechClub.</span>
                    <span class="small text-muted ms-2">&copy; @DateTime.Now.Year Tüm hakları saklıdır.</span>
                </div>
                <div class="d-flex gap-4 small">
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted hover-text-white transition-color">Gizlilik Politikası</a>
                    <a asp-controller="Home" asp-action="Contact" class="text-decoration-none text-muted hover-text-white transition-color">İletişim</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
