@{
    // Define the default layout conditionally based on the path
    if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin")
    {
        // Don't apply layout for Login page, otherwise apply AdminLayout
        if (ViewContext.RouteData.Values["Action"]?.ToString() == "Login")
        {
            Layout = null; 
        }
        else
        {
            Layout = "~/Views/Shared/_AdminLayout.cshtml";
        }
    }
    else
    {
        Layout = "_Layout";
    }
}
